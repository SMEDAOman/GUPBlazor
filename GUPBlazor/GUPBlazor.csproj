<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>GUPBlazor</Title>
    <Authors>SMEDAOman</Authors>
    <Company>SMEDAOman</Company>
    <Product>GUPBlazor</Product>
    <RepositoryUrl>https://github.com/SMEDAOman/GUPBlazor</RepositoryUrl>
    <PackageProjectUrl>https://github.com/SMEDAOman/GUPBlazor</PackageProjectUrl>
    <Version>0.0.9</Version>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>



</Project>
