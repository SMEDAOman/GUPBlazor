@* Equivalent of <gup-form-section>
   Named slot: Title (section heading)
*@
<div class="gup-form-section">
    @if (Title != null)
    {
        <div class="title">@Title</div>
    }
    <div class="inner">
        @ChildContent
    </div>
</div>

@code {
    [Parameter] public RenderFragment? Title { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
