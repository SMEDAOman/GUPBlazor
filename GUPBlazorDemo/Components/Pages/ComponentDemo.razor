@page "/"
@inject NavigationManager Nav

<PageTitle>Component Demo — Gov.om Design System</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Primary"
                           Kind="@GupButtonKind.Button"
                           OnClick="@(() => Nav.NavigateTo("/"))">
                    <ChildContent>← Back to templates</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Component Demo">
        <PageSummary>All Gov.om design-system Blazor components, organized by category.</PageSummary>
    </GupContentHeader>
  
    <div class="demo-body">
        <div class="demo-index-grid">

            <a href="/service-start" class="demo-index-card">
                <h3>Service Start</h3>
                <p>Service Start Demo.</p>
            </a>

            <a href="/demo/branding" class="demo-index-card">
                <h3>Branding</h3>
                <p>Logo, icons, color tokens, and typography scale.</p>
            </a>

            <a href="/demo/buttons" class="demo-index-card">
                <h3>Buttons</h3>
                <p>Button appearances, icons, disabled states, and button groups.</p>
            </a>

            <a href="/demo/forms" class="demo-index-card">
                <h3>Form Components (all-in-one)</h3>
                <p>Input fields, form sections, checkboxes, radio buttons, and dropdowns.</p>
            </a>

            <a href="/demo/file-upload" class="demo-index-card">
                <h3>File Upload</h3>
                <p>Single &amp; multi-file upload with thumbnails, size validation, and file library.</p>
            </a>

            <a href="/demo/layout" class="demo-index-card">
                <h3>Layout</h3>
                <p>Track, header, content header, and wizard footer.</p>
            </a>

            <a href="/demo/feedback" class="demo-index-card">
                <h3>Feedback</h3>
                <p>Banners, steppers, and disclosure/details.</p>
            </a>

            <a href="/demo/badges" class="demo-index-card">
                <h3>Badge</h3>
                <p>Status dot — neutral, positive, negative, and offline.</p>
            </a>

            <a href="/demo/toasts" class="demo-index-card">
                <h3>Toasts</h3>
                <p>Short notifications with severities and a dynamic container.</p>
            </a>

            <a href="/demo/spinner" class="demo-index-card">
                <h3>Spinner</h3>
                <p>Accessible loading indicator — sizes, text, and in-context examples.</p>
            </a>

            <a href="/demo/data-display" class="demo-index-card">
                <h3>Data Display</h3>
                <p>Tables, rich text, and links.</p>
            </a>

        </div>

        <h2 class="demo-section-title" style="margin-top: 48px;">Individual Input Components</h2>
        <p style="color: var(--gup-color-content-secondary, #52525b); margin-bottom: 16px;">
            Focused demos — one component type per page.
        </p>
        <div class="demo-index-grid">

            <a href="/demo/inputs/text" class="demo-index-card">
                <h3>Text Input</h3>
                <p>GupInputField with Type="text" — default, placeholder, read-only, disabled.</p>
            </a>

            <a href="/demo/inputs/email" class="demo-index-card">
                <h3>Email Input</h3>
                <p>GupInputField with Type="email" — email-specific keyboard &amp; validation.</p>
            </a>

            <a href="/demo/inputs/tel" class="demo-index-card">
                <h3>Phone Input</h3>
                <p>GupInputField with Type="tel" — numeric keypad on mobile.</p>
            </a>

            <a href="/demo/inputs/date" class="demo-index-card">
                <h3>Date Input</h3>
                <p>GupInputField with date, time, datetime-local, and month types.</p>
            </a>

            <a href="/demo/inputs/number" class="demo-index-card">
                <h3>Number Input</h3>
                <p>GupInputField with Type="number" — integer, decimal, read-only, disabled.</p>
            </a>

            <a href="/demo/inputs/password" class="demo-index-card">
                <h3>Password Input</h3>
                <p>GupInputField with Type="password" — masked entry, login form example.</p>
            </a>

            <a href="/demo/inputs/dropdown" class="demo-index-card">
                <h3>Dropdown</h3>
                <p>Single/multi-select, search, clearable, error, and loading states.</p>
            </a>

            <a href="/demo/inputs/checkbox" class="demo-index-card">
                <h3>Checkbox</h3>
                <p>Default, checked, disabled, small, circle, and grouped variants.</p>
            </a>

            <a href="/demo/inputs/radio" class="demo-index-card">
                <h3>Radio Button</h3>
                <p>GupRadioButtonGroup with hints, pre-selection, and disabled options.</p>
            </a>

        </div>
    </div>

</div>
