@page "/templates"

<PageTitle>Gov.om Templates</PageTitle>

<div style="max-width: 600px; margin: 60px auto; padding: 32px; font-family: var(--font-base, sans-serif);">
    <h1 style="font-size: 32px; font-weight: 700; color: var(--gup-color-content-primary, #27272a); margin-bottom: 8px;">
        Gov.om Design System — Blazor Templates
    </h1>
    <p style="color: var(--gup-color-content-secondary, #52525b); margin-bottom: 32px;">
        Blazor implementation of the GUP web component templates. All CSS and assets are bundled — no npm required.
    </p>
    <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 12px;">
        <li>
            <a href="/" style="color: var(--gup-color-content-link, #132459); text-decoration: underline; font-size: 18px;">
                Service Start
            </a>
            <span style="color: var(--gup-color-content-tertiary, #7a7a83); font-size: 14px; margin-left: 8px;">/</span>
        </li>
        <li>
            <a href="/sign-in" style="color: var(--gup-color-content-link, #132459); text-decoration: underline; font-size: 18px;">
                Service Provider Sign In
            </a>
            <span style="color: var(--gup-color-content-tertiary, #7a7a83); font-size: 14px; margin-left: 8px;">/sign-in</span>
        </li>
        <li>
            <a href="/application-completed" style="color: var(--gup-color-content-link, #132459); text-decoration: underline; font-size: 18px;">
                Application Completed
            </a>
            <span style="color: var(--gup-color-content-tertiary, #7a7a83); font-size: 14px; margin-left: 8px;">/application-completed</span>
        </li>
        <li>
            <a href="/help" style="color: var(--gup-color-content-link, #132459); text-decoration: underline; font-size: 18px;">
                Help Service
            </a>
            <span style="color: var(--gup-color-content-tertiary, #7a7a83); font-size: 14px; margin-left: 8px;">/help</span>
        </li>
    </ul>

    <div style="margin-top: 32px; padding-top: 24px; border-top: 1px solid var(--gup-color-border-low);">
        <a href="/demo" style="color: var(--gup-color-brand-medium, #2f57cd); text-decoration: underline; font-size: 18px; font-weight: 700;">
            → Component Demo (all 23 components)
        </a>
    </div>
</div>
