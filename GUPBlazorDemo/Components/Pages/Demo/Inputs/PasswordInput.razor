@page "/demo/inputs/password"

<PageTitle>Password Input — Component Demo</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Link" Href="/">
                    <ChildContent>← Back to demo</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Password Input">
        <PageSummary>GupInputField with <code>Type="password"</code>. Masks the value as it is typed.</PageSummary>
    </GupContentHeader>

    <div class="demo-body">

        <section class="demo-section">
            <h2 class="demo-section-title">Basic</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Default</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="pwd-default" Type="password">Password</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">With placeholder</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="pwd-placeholder" Type="password" Placeholder="At least 8 characters">Password</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Login Form Example</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupFormList>
                        <GupInputField Name="login-user" Type="text" Placeholder="username or ID">Username</GupInputField>
                        <GupInputField Name="login-pwd" Type="password" Placeholder="Enter your password">Password</GupInputField>
                        <GupInputField Name="login-confirm" Type="password" Placeholder="Re-enter your password">Confirm password</GupInputField>
                    </GupFormList>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">States</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Disabled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="pwd-disabled" Type="password" Disabled="true">Password (disabled)</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

    </div>
</div>
