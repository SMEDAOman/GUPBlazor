@page "/demo/inputs/text"
@rendermode InteractiveServer

<PageTitle>Text Input — Component Demo</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Link" Href="/">
                    <ChildContent>← Back to demo</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Text Input">
        <PageSummary>GupInputField with <code>Type="text"</code> and the generic features that apply to every type: required, hint, validation, slots, length and pattern constraints.</PageSummary>
    </GupContentHeader>

    <div class="demo-body">

        <section class="demo-section">
            <h2 class="demo-section-title">Basic Text Inputs</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Default</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-default" Type="text">Full name</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">With placeholder</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-placeholder" Type="text" Placeholder="e.g. Ahmed Al Habsi">Full name</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Required</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-required" Type="text" Required="true">Required field</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">States</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Pre-filled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-value" Type="text" Value="Ahmed Al Habsi">Full name</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Read-only</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-readonly" Type="text" Value="Cannot edit" Readonly="true">Read-only field</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Disabled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-disabled" Type="text" Disabled="true">Disabled field</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Label hidden</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-label-hidden" Type="text" LabelHidden="true" Placeholder="Search…">Search</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Hint &amp; Validation</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">With hint</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-hint" Type="text">
                                <ChildContent>Civil ID number</ChildContent>
                                <Hint>Enter the number as shown on your ID card.</Hint>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Invalid (default message)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-invalid" Type="text" Required="true" IsInvalid="true">Required field</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Custom error message</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-invalid-custom"
                                           Type="text"
                                           IsInvalid="true"
                                           ErrorMessage="Please enter a valid message of 10–100 characters.">
                                Your message
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Toggle invalid</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-invalid-toggle"
                                           Type="text"
                                           IsInvalid="@_toggleInvalid"
                                           ErrorMessage="This message is shown only when invalid.">
                                Watch the validation message
                            </GupInputField>
                        </GupFormList>
                        <GupButton Appearance="@GupButtonAppearance.Secondary"
                                   Kind="@GupButtonKind.Button"
                                   OnClick="@(() => _toggleInvalid = !_toggleInvalid)">
                            <ChildContent>Toggle invalid (@(_toggleInvalid ? "on" : "off"))</ChildContent>
                        </GupButton>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Prefix &amp; Suffix</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">With prefix</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-prefix" Type="text" Placeholder="12345678">
                                <ChildContent>Bank account</ChildContent>
                                <Prefix>OMR</Prefix>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">With suffix</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-suffix" Type="text" Placeholder="example">
                                <ChildContent>Domain</ChildContent>
                                <Suffix>.gov.om</Suffix>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Both</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-both-affix" Type="text" Placeholder="amount">
                                <ChildContent>Total</ChildContent>
                                <Prefix>OMR</Prefix>
                                <Suffix>.000</Suffix>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Input-start &amp; Input-end slots</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">With input-start (search icon)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-input-start" Type="text" Placeholder="Search…">
                                <ChildContent>Search</ChildContent>
                                <InputStart>
                                    <GupIcon IconName="search" Width="20" Height="20" />
                                </InputStart>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">With input-end (chevron)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-input-end" Type="text" Placeholder="Pick an option…">
                                <ChildContent>Selector</ChildContent>
                                <InputEnd>
                                    <GupIcon IconName="keyboard-arrow-down" Width="20" Height="20" />
                                </InputEnd>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">All slots</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-all-slots" Type="text" Placeholder="123.456">
                                <ChildContent>Amount</ChildContent>
                                <Prefix>OMR</Prefix>
                                <Suffix>.000</Suffix>
                                <InputStart>
                                    <GupIcon IconName="search" Width="20" Height="20" />
                                </InputStart>
                                <InputEnd>
                                    <GupIcon IconName="keyboard-arrow-down" Width="20" Height="20" />
                                </InputEnd>
                                <Hint>Every slot is filled in this example.</Hint>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Length &amp; Pattern Constraints</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Max char limit (10)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-maxlen" Type="text" MaxLength="10" Placeholder="Up to 10 chars">Short text</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Numeric (validates, doesn't filter)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-numeric" Type="numeric" Placeholder="0-9 only">Numeric value</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Numeric (StrictNumeric — filters non-digits)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-numeric-strict" Type="numeric" StrictNumeric="true" Placeholder="Try typing letters">Strict numeric value</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Strict 4-digit PIN</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="txt-pin" Type="numeric" StrictNumeric="true" Pattern="\d{4,4}" MaxLength="4" Placeholder="4-digit PIN">Enter your 4-digit PIN</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Two-way Binding (@@bind-Value)</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupFormList>
                        <GupInputField Name="txt-bind" Type="text" Placeholder="Type something..." @bind-Value="_boundValue">Bound input</GupInputField>
                    </GupFormList>
                    <p data-testid="bind-output" style="margin-top: 12px;">
                        Bound value: <strong>@(_boundValue ?? "(empty)")</strong>
                    </p>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Events</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupFormList>
                        <GupInputField Name="txt-events"
                                       Type="text"
                                       Placeholder="Try typing, focusing, blurring..."
                                       OnValueChange="HandleValueChange"
                                       OnChange="HandleChange"
                                       OnKeyDown="HandleKeyDown"
                                       OnFocus="HandleFocus">
                            Event-tracked input
                        </GupInputField>
                    </GupFormList>
                    <ul style="margin-top: 12px; line-height: 1.8;">
                        <li><strong>OnValueChange</strong> (every keystroke): <code>@(_lastChangeValue ?? "(none)")</code> — fired @_changeCount times</li>
                        <li><strong>OnChange</strong> (commit/blur): <code>@(_lastCommitted ?? "(none)")</code> — fired @_commitCount times</li>
                        <li><strong>OnKeyDown</strong>: <code>@(_lastKey ?? "(none)")</code> — fired @_keyCount times</li>
                        <li><strong>OnFocus</strong>: fired @_focusCount times</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Multiple Fields in a Form List</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupFormList>
                        <GupInputField Name="first-name" Type="text" Required="true">First name</GupInputField>
                        <GupInputField Name="middle-name" Type="text">Middle name</GupInputField>
                        <GupInputField Name="last-name" Type="text" Required="true">Last name</GupInputField>
                        <GupInputField Name="national-id" Type="numeric" StrictNumeric="true" MaxLength="8" Placeholder="8-digit number">
                            <ChildContent>National ID</ChildContent>
                            <Hint>Enter the number as shown on your ID card.</Hint>
                        </GupInputField>
                    </GupFormList>
                </div>
            </div>
        </section>

    </div>
</div>

@code {
    private string? _boundValue;

    private string? _lastChangeValue;
    private int _changeCount;

    private string? _lastCommitted;
    private int _commitCount;

    private string? _lastKey;
    private int _keyCount;

    private int _focusCount;

    private bool _toggleInvalid;

    private void HandleValueChange(string? value)
    {
        _lastChangeValue = value;
        _changeCount++;
    }

    private void HandleChange(string? value)
    {
        _lastCommitted = value;
        _commitCount++;
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        _lastKey = e.Key;
        _keyCount++;
    }

    private void HandleFocus(FocusEventArgs _)
    {
        _focusCount++;
    }
}
