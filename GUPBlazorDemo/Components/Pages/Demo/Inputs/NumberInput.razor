@page "/demo/inputs/number"

<PageTitle>Number Input — Component Demo</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Link" Href="/">
                    <ChildContent>← Back to demo</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Number Input">
        <PageSummary>GupInputField with <code>Type="number"</code>. Accepts numeric values with optional min/max/step.</PageSummary>
    </GupContentHeader>

    <div class="demo-body">

        <section class="demo-section">
            <h2 class="demo-section-title">Basic</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Default</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="num-default" Type="number">Quantity</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">With placeholder</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="num-placeholder" Type="number" Placeholder="0">Dependants</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Pre-filled values</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Integer</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="num-integer" Type="number" Value="42">Age</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Decimal</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="num-decimal" Type="number" Value="1250.75">Fee amount (OMR)</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">States</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Read-only</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="num-readonly" Type="number" Value="100" Readonly="true">Calculated amount</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Disabled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="num-disabled" Type="number" Disabled="true">Unavailable</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

    </div>
</div>
