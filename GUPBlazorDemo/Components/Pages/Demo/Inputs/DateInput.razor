@page "/demo/inputs/date"
@rendermode InteractiveServer

<PageTitle>Date Input — Component Demo</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Link" Href="/">
                    <ChildContent>← Back to demo</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Date Input">
        <PageSummary>GupInputField with <code>Type="date"</code>, <code>"time"</code>, <code>"datetime-local"</code>, and <code>"month"</code>. Two-way binding and event handling.</PageSummary>
    </GupContentHeader>

    <div class="demo-body">

        <section class="demo-section">
            <h2 class="demo-section-title">Date</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Default</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="date-default" Type="date">Date of birth</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Pre-filled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="date-value" Type="date" Value="1990-06-15">Date of birth</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Time / Date-Time / Month</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Time</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="time-input" Type="time">Appointment time</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Date-time</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="datetime-input" Type="datetime-local">Appointment slot</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Month</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="month-input" Type="month">Billing month</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">States</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Read-only</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="date-readonly" Type="date" Value="2025-01-01" Readonly="true">Issue date</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Disabled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="date-disabled" Type="date" Disabled="true">Unavailable</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Two-way Binding (@@bind-Value)</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupFormList>
                        <GupInputField Name="date-bind" Type="date" @bind-Value="_boundValue">Bound date</GupInputField>
                    </GupFormList>
                    <p data-testid="bind-output" style="margin-top: 12px;">
                        Bound value: <strong>@(_boundValue ?? "(empty)")</strong>
                    </p>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">OnValueChange Event</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupFormList>
                        <GupInputField Name="date-change" Type="date" OnValueChange="HandleValueChange">Change-tracked date</GupInputField>
                    </GupFormList>
                    <p data-testid="change-log" style="margin-top: 12px;">
                        Last value: <strong>@(_lastChangeValue ?? "(none)")</strong> (count: @_changeCount)
                    </p>
                </div>
            </div>
        </section>

    </div>
</div>

@code {
    private string? _boundValue;

    private string? _lastChangeValue;
    private int _changeCount;

    private void HandleValueChange(string? value)
    {
        _lastChangeValue = value;
        _changeCount++;
    }
}
