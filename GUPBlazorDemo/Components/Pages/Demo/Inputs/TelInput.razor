@page "/demo/inputs/tel"
@rendermode InteractiveServer

<PageTitle>Phone Input — Component Demo</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Link" Href="/">
                    <ChildContent>← Back to demo</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Phone / Tel Input">
        <PageSummary>GupInputField with <code>Type="tel"</code>. Triggers the numeric keypad on mobile and can be locked to digits-only with <code>StrictNumeric</code>.</PageSummary>
    </GupContentHeader>

    <div class="demo-body">

        <section class="demo-section">
            <h2 class="demo-section-title">Basic</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Default</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-default" Type="tel">Mobile number</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">With placeholder</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-placeholder" Type="tel" Placeholder="+968 9XXX XXXX">Mobile number</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">States</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Pre-filled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-value" Type="tel" Value="+96899123456">Primary phone</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Read-only</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-readonly" Type="tel" Value="+96899123456" Readonly="true">Verified number</GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Disabled</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-disabled" Type="tel" Disabled="true">Disabled phone</GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Validation</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Oman mobile (8 digits, digits-only)</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-oman"
                                           Type="tel"
                                           StrictNumeric="true"
                                           Pattern="\d{8,8}"
                                           MaxLength="8"
                                           Placeholder="9XXXXXXX">
                                <ChildContent>Mobile number</ChildContent>
                                <Hint>Try typing letters or symbols — only digits will go through.</Hint>
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Required</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-required"
                                           Type="tel"
                                           StrictNumeric="true"
                                           Pattern="\d{8,8}"
                                           MaxLength="8"
                                           Required="true"
                                           Placeholder="9XXXXXXX">
                                Mobile number
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Custom error message</span>
                    <div class="demo-surface">
                        <GupFormList>
                            <GupInputField Name="tel-custom-error"
                                           Type="tel"
                                           StrictNumeric="true"
                                           Pattern="\d{8,8}"
                                           MaxLength="8"
                                           ErrorMessage="Please enter an 8-digit Oman mobile number."
                                           Placeholder="9XXXXXXX">
                                Mobile number
                            </GupInputField>
                        </GupFormList>
                    </div>
                </div>
            </div>
        </section>

    </div>
</div>
