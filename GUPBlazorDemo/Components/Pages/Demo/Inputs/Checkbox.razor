@page "/demo/inputs/checkbox"

<PageTitle>Checkbox — Component Demo</PageTitle>

<div class="demo-page">

    <GupHeader NavAriaLabel="Demo Navigation">
        <Start>
            <GupTrack Direction="horizontal" Gap="2">
                <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Link" Href="/">
                    <ChildContent>← Back to demo</ChildContent>
                </GupButton>
            </GupTrack>
        </Start>
    </GupHeader>

    <GupContentHeader PageTitle="Checkbox">
        <PageSummary>GupCheckbox in default, checked, disabled, small, and circle variants — individually and in groups.</PageSummary>
    </GupContentHeader>

    <div class="demo-body">

        <section class="demo-section">
            <h2 class="demo-section-title">Default</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Single, unchecked</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-terms" Value="accepted">
                            <ChildContent>I accept the terms and conditions</ChildContent>
                            <Hint>Please read the terms before accepting.</Hint>
                        </GupCheckbox>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Single, checked</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-newsletter" Checked="true">
                            <ChildContent>Subscribe to newsletter</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Disabled States</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Unchecked + disabled</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-unavailable" Disabled="true">
                            <ChildContent>This option is disabled</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Checked + disabled</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-checked-disabled" Checked="true" Disabled="true">
                            <ChildContent>Checked &amp; disabled</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Sizes</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Medium (default)</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-m-1">
                            <ChildContent>Medium checkbox</ChildContent>
                        </GupCheckbox>
                        <GupCheckbox Name="cb-m-2" Checked="true">
                            <ChildContent>Medium checked</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Small</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-s-1" Size="s">
                            <ChildContent>Small checkbox</ChildContent>
                        </GupCheckbox>
                        <GupCheckbox Name="cb-s-2" Size="s" Checked="true">
                            <ChildContent>Small checked</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Circle Appearance</h2>
            <div class="demo-row">
                <div class="demo-card">
                    <span class="demo-card-label">Circle</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-circle-1" Appearance="circle">
                            <ChildContent>Circle checkbox</ChildContent>
                        </GupCheckbox>
                        <GupCheckbox Name="cb-circle-2" Appearance="circle" Checked="true">
                            <ChildContent>Circle checked</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
                <div class="demo-card">
                    <span class="demo-card-label">Small circle</span>
                    <div class="demo-surface">
                        <GupCheckbox Name="cb-small-circle" Size="s" Appearance="circle" Checked="true">
                            <ChildContent>Small circle checked</ChildContent>
                        </GupCheckbox>
                    </div>
                </div>
            </div>
        </section>

        <section class="demo-section">
            <h2 class="demo-section-title">Checkbox Group (multi-select)</h2>
            <div class="demo-card--full">
                <div class="demo-surface">
                    <GupCheckbox Name="services" Value="civil-status">
                        <ChildContent>Civil status</ChildContent>
                    </GupCheckbox>
                    <GupCheckbox Name="services" Value="business-reg" Checked="true">
                        <ChildContent>Business registration</ChildContent>
                    </GupCheckbox>
                    <GupCheckbox Name="services" Value="vehicle-lic">
                        <ChildContent>Vehicle licensing</ChildContent>
                    </GupCheckbox>
                    <GupCheckbox Name="services" Value="health">
                        <ChildContent>Health services</ChildContent>
                    </GupCheckbox>
                </div>
            </div>
        </section>

    </div>
</div>
