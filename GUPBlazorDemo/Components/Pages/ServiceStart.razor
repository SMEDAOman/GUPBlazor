@page "/service-start"
@rendermode InteractiveServer

<PageTitle>Service Start — Gov.om Templates</PageTitle>

<GUPWizardStack @ref="_wizard"
                PageTitle="Service name"
                @bind-CurrentStepIndex="_currentStep"
                IsLoading="@_isLoading"
                OnStepChanged="HandleStepChanged"
                PageSubtitle="A brief description of the service, its requirements, or instructions for the user can go here. It can be a couple of sentences long."

               >
    <PageSummary>
        <p>Summary content goes here. It can be a few sentences long and include <strong>formatted text</strong>, links, or other elements.</p>
    </PageSummary>

    <HeaderStart>
        
        <GupTrack Direction="horizontal" Gap="2">
            <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Button" Type="@GupButtonType.Button">
                <IconStart><GupIcon IconName="close" Width="24" Height="24" /></IconStart>
                <ChildContent>Save &amp; exit</ChildContent>
            </GupButton>
        </GupTrack>
    </HeaderStart>

    <HeaderEnd>
        <GupTrack Direction="horizontal" HorizontalAlignment="right" Gap="2">
            <GupButton Appearance="@GupButtonAppearance.Text" Kind="@GupButtonKind.Button" Type="@GupButtonType.Button">
                <IconStart><GupIcon IconName="live-help" Width="24" Height="24" /></IconStart>
                <ChildContent>Do you need help?</ChildContent>
            </GupButton>
        </GupTrack>
    </HeaderEnd>

    <ChildContent>

        <GUPWizardStackStep Title="Applicant details"
                            Description="Tell us who is applying."
                            NextButtonText="Continue to service details">
            <form>
                <GupFormSection>
                    <Title>Personal information</Title>
                    <ChildContent>
                        <GupFormList>
                            <GupInputField Name="full-name" Type="text">Full name</GupInputField>
                            <GupInputField Name="civil-id" Type="text">Civil ID</GupInputField>
                            <GupInputField Name="email" Type="email">Email</GupInputField>
                        </GupFormList>
                    </ChildContent>
                </GupFormSection>
            </form>
        </GUPWizardStackStep>

        <GUPWizardStackStep Title="Service details"
                            Description="Lock this step to disable Continue."
                            Locked="@_lockServiceDetails"
                            BackButtonText="Edit applicant"
                            OnNext="Handle1"
                            >
            <GupFormSection>
                <Title>Request</Title>
                <ChildContent>
                    <label style="display: inline-flex; align-items: center; gap: 8px; font-size: 18px; color: var(--gup-color-content-primary); margin-bottom: 16px;">
                        <input type="checkbox" @bind="_lockServiceDetails" />
                        <span>Lock this step (disables the Continue button)</span>
                    </label>
                    <GupFormList>
                        <GupInputField Name="subject" Type="text">Subject</GupInputField>
                        <GupInputField Name="reference" Type="text">Reference number</GupInputField>
                        <GupInputField Name="notes" Type="text">Additional notes</GupInputField>
                    </GupFormList>
                </ChildContent>
            </GupFormSection>
        </GUPWizardStackStep>

        <GUPWizardStackStep Title="Review"
                            Description="Toggle the option below to demo the per-step OnNext cancel flow."
                            NextButtonText="Submit"
                            OnNext="HandleReviewNext">
            <GupFormSection>
                <Title>Confirm</Title>
                <ChildContent>
                    <label style="display: inline-flex; align-items: center; gap: 8px; font-size: 18px; color: var(--gup-color-content-primary);">
                        <input type="checkbox" @bind="_blockSubmit" />
                        <span>Block the next click (step's <code>OnNext</code> will set <code>args.Cancel = true</code>)</span>
                    </label>
                </ChildContent>
            </GupFormSection>
        </GUPWizardStackStep>

        <GUPWizardStackStep Title="Done"
                            Description="Your request has been submitted."
                            NextButtonText="Finish"
                            BackButtonText="Back to review"
                            OnNext="HandleComplete">
            <GupFormSection>
                <Title>Thank you</Title>
                <ChildContent>
                    <p style="font-size: 18px; color: var(--gup-color-content-primary);">
                        Reference <strong>@_submittedReference</strong> — keep this number for your records.
                    </p>
                </ChildContent>
            </GupFormSection>
        </GUPWizardStackStep>

    </ChildContent>

</GUPWizardStack>

@* <div style="position: fixed; top: 88px; right: 16px; width: 240px; padding: 12px 16px; background: rgba(0,0,0,0.78); color: #fff; font-family: monospace; font-size: 12px; border-radius: 8px; z-index: 1000;">
    <strong>Programmatic control</strong>
    <div style="display: flex; flex-direction: column; gap: 6px; margin-top: 8px;">
        <button type="button" @onclick="WizardBack">wizard.BackAsync()</button>
        <button type="button" @onclick="WizardNext">wizard.NextAsync()</button>
        <div style="display:flex; gap:4px;">
            @for (var i = 0; i < 4; i++)
            {
                var idx = i;
                <button type="button" style="flex:1" @onclick="() => WizardGoTo(idx)">@idx</button>
            }
        </div>
        <small>step @_currentStep / locked: @(_wizard?.CurrentStep?.Locked == true)</small>
    </div>
</div> *@

@if (_log.Count > 0)
{
    <div style="position: fixed; bottom: 96px; right: 16px; width: 320px; padding: 12px 16px; background: rgba(0,0,0,0.78); color: #fff; font-family: monospace; font-size: 12px; border-radius: 8px; max-height: 200px; overflow-y: auto; z-index: 1000;">
        <strong>Wizard events</strong>
        <ul style="margin: 8px 0 0 0; padding-left: 16px;">
            @foreach (var entry in _log)
            {
                <li>@entry</li>
            }
        </ul>
    </div>
}

@code {
    private GUPWizardStack? _wizard;
    private int _currentStep;
    private bool _blockSubmit;
    private bool _lockServiceDetails;
    private bool _isLoading;
    private string _submittedReference = "";
    private readonly List<string> _log = new();

    private Task HandleReviewNext(GupWizardNavArgs args)
    {
        if (_blockSubmit)
        {
            args.Cancel = true;
            Log($"Review step blocked submit (step {args.CurrentStepIndex})");
        }
        return Task.CompletedTask;
    }

    private Task HandleStepChanged(int index)
    {
        Log($"Step changed → {index}");
        return Task.CompletedTask;
    }

    private async Task HandleComplete(GupWizardNavArgs args)
    {

        _isLoading = true;
        Log($"Loading start (step {args.CurrentStepIndex})");
        StateHasChanged();

        try
        {
            await Task.Delay(2000);
             _submittedReference = $"REQ-{DateTime.UtcNow:yyMMddHHmmss}";
            Log($"Completed at step {args.CurrentStepIndex} (ref {_submittedReference})");
        }
        finally
        {
            _isLoading = false;
            await Task.CompletedTask;
        }
        StateHasChanged();
    }

    private Task WizardBack() => _wizard?.BackAsync() ?? Task.CompletedTask;
    private Task WizardNext() => _wizard?.NextAsync() ?? Task.CompletedTask;
    private Task WizardGoTo(int index) => _wizard?.GoToStepAsync(index) ?? Task.CompletedTask;

    private void Log(string entry)
    {
        _log.Insert(0, $"{DateTime.Now:HH:mm:ss}  {entry}");
        if (_log.Count > 8) _log.RemoveAt(_log.Count - 1);
    }

    private async Task Handle1(GupWizardNavArgs args)
    {
        _isLoading = true;
        Log($"Loading start (step {args.CurrentStepIndex})");
        StateHasChanged();

        try
        {
            await Task.Delay(2000);
            Log($"Loading done (step {args.CurrentStepIndex})");
        }
        finally
        {
            _isLoading = false;
        }
    }



}

